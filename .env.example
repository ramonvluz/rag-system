# =============================================================
# RAG System — Configuração
# Copie para .env e preencha os valores necessários.
# =============================================================

# ── LLM ──────────────────────────────────────────────────────
# Provedor ativo: groq | ollama | auto
# auto → tenta Ollama primeiro, cai para Groq se indisponível
LLM_PROVIDER=groq
LLM_TEMPERATURE=0.1

# Groq — obrigatório se LLM_PROVIDER=groq ou auto
GROQ_API_KEY=sua_chave_aqui

# Modelos disponíveis no Groq (free tier → paid):
#   llama-3.1-8b-instant   — rápido, gratuito, menor qualidade
#   llama-3.3-70b-versatile — lento, pago,    maior qualidade
GROQ_MODEL=llama-3.1-8b-instant

# Ollama — opcional, necessário se LLM_PROVIDER=ollama ou auto
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=60

# ── EMBEDDING ────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BATCH_SIZE=16

# ── RERANKER ─────────────────────────────────────────────────
RERANKER_MODEL=BAAI/bge-reranker-base

# ── CHUNKING ─────────────────────────────────────────────────
CHUNK_SIZE=768
CHUNK_OVERLAP=200

# ── RETRIEVAL ────────────────────────────────────────────────
VECTOR_SEARCH_TOP_K=20
HYBRID_SEMANTIC_WEIGHT=0.7
HYBRID_BM25_WEIGHT=0.3
RERANKER_TOP_K=5

# ── VECTOR STORE ─────────────────────────────────────────────
CHROMA_COLLECTION_NAME=rag_system

# ── AVALIAÇÃO RAGAS ──────────────────────────────────────────
# Modelo juiz para avaliação. Use eval-fast ou eval-quality no
# Makefile para alternar sem editar este arquivo.
#   llama-3.1-8b-instant    → rápido, free tier
#   llama-3.3-70b-versatile → qualidade máxima, pago
RAGAS_GROQ_MODEL=llama-3.1-8b-instant
RAGAS_MAX_CHUNKS=3
RAGAS_MAX_CHUNK_CHARS=500